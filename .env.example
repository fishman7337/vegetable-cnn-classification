# Project identity
PROJECT_NAME=vegetable-vision-cnn

# Dataset layout expected by the notebook and training CLI:
# DATASET_DIR/
#   train/<class_name>/*.jpg
#   validation/<class_name>/*.jpg
#   test/<class_name>/*.jpg
DATASET_DIR=data/raw/Dataset (A)

# Output locations
OUTPUT_DIR=artifacts
MODEL_DIR=models
REPORTS_DIR=reports

# Training defaults
IMAGE_SIZE=101
COLOR_MODE=grayscale
BATCH_SIZE=32
EPOCHS=100
LEARNING_RATE=0.001
SEED=42
USE_AUGMENTATION=true
USE_CLASS_WEIGHTING=true
